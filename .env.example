APP_NAME=Business Location Intelligence API
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/bizintel
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=change-me-to-a-real-secret-outside-development
MODEL_ARTIFACT_DIR=/app/model_artifacts

# Optional: enables the AI Business Advisor endpoint. Without it, the
# endpoint returns a clear "advisor unavailable" response instead of
# fabricated advice. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
